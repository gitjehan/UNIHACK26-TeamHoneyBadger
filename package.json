    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx src scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:ambient": "tsx scripts/test-ambient.ts",
    "test:ipc": "tsx scripts/test-ipc.ts",
    "test:e2e": "tsx scripts/test-e2e-auto.ts",
    "test:e2e:manual": "tsx scripts/test-e2e.ts",
    "verify": "npm run lint && npm run typecheck && npm run test:unit"
  },
